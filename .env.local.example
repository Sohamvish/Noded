# Supabase
NEXT_PUBLIC_SUPABASE_URL="your-supabase-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Optional: OAuth/magic-link redirects (defaults to window origin in browser)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only: NEVER expose to browser (used by scripts/ingest_neu.ts)
SUPABASE_URL="your-supabase-url"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# NEU ingestion (clone NotEnoughUpdates-REPO into this path)
NEU_REPO_PATH=./neu-data

# Hypixel API (server-only — never commit real keys)
# Keys are managed at https://developer.hypixel.net/dashboard/
#
# Development (pre-1.0): Temporary API key — short-lived, regenerate regularly.
# Production (post-1.0): Apply for a Production API key after release; it does not expire.
#
# In-game keys from `/api new` also work for testing but expire after ~72 hours.
HYPIXEL_API_KEY="your-hypixel-api-key"
